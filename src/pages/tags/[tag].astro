---
import Base from '../../layouts/Base.astro';
import { getPublishedNotes, getAllTags, noteUrl, noteCategory, type Note } from '../../lib/notes';

export async function getStaticPaths() {
  const notes = await getPublishedNotes();
  return [...getAllTags(notes).entries()].map(([tag, tagged]) => ({
    params: { tag },
    props: { tag, tagged },
  }));
}

interface Props {
  tag: string;
  tagged: Note[];
}
const { tag, tagged } = Astro.props;
---

<Base title={`标签：${tag}`}>
  <h1>#{tag}</h1>
  <ul>
    {
      tagged.map((note) => (
        <li>
          <a href={noteUrl(note)}>{note.data.title}</a>
          <small> · {noteCategory(note)}</small>
        </li>
      ))
    }
  </ul>
</Base>
