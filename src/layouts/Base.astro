---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · sortingMyself</title>
  </head>
  <body>
    <header>
      <a href="/" class="site-title">
        <span class="seal">整</span>
        <strong>sortingMyself</strong>
      </a>
      <nav>
        <a href="/">首页</a>
        <a href="/tags/">标签</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <span class="ornament">◆ ◆ ◆</span>
      Built with Astro · Deployed on Vercel
    </footer>
  </body>
</html>
